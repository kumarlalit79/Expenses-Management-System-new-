        function CategoryWiseSpendingfun(monthno) {
            //alert('Aashi');
            // alert(monthno);
            //Convert monthno to integer
            var monthNumber = parseInt(monthno, 10);
            //alert('Lucky');
            if (isNaN(monthNumber)) { monthNumber = 0; }
            //alert(monthNumber);
            $.ajax({
                url: '@Url.Action("CategoryWiseSpending", "Dashboard")', // Ensure correct controller name
                data: { currentmonth: monthNumber }, // Pass the integer month number
                type: 'GET',
                success: function (result) {
                    // Handle the successful response here
                    console.log(result); // Process and display the data
                    // Clear previous data
                    $('#Category_Wise_Spending').empty();

                    var vtotal = 0;
                    // Populate the table with new data
                    for (var i = 0; i < result.length; i++) {
                        var price = parseFloat(result[i].total_price);
                        vtotal += price;
                        var row = $('<tr>'); // Create a new table row
                        row.append($('<td>').text(i + 1)); // Add row number
                        row.append($('<td style="text-align: left;">').text(result[i].cat_name)); // Add category name
                        row.append($('<td style="text-align: right;">').text(result[i].total_price)); // Add price
                        $('#Category_Wise_Spending').append(row); // Append row to table body
                    }
                    var $tfoot = $('#uniqueCatId');
                    if ($tfoot.length === 0) {
                        // Create new tfoot if not present
                        $tfoot = $('<tfoot id="uniqueCatId"></tfoot>');
                        $('table').append($tfoot);
                    } else {
                        // Clear existing tfoot if present
                        $tfoot.empty();
                    }

                    // Append new footer content
                    $('#uniqueCatId').append('<tr><td colspan="2"><strong>Total</strong></td><td style="text-align:right"><strong>' + vtotal.toFixed(2) + '</strong></td></tr>');

                },
                error: function (xhr, status, error) {
                    alert('An error occurred: ' + error);
                }
            });
        }


        function BindLineChart() {

            // alert('Line--Chart');
            $.ajax({
                url: '@Url.Action("GetMonthWiseWiseRPT", "Dashboard")',

                type: 'GET',
                success: function (result) {

                    var MonthName1 = result.map(function (item) {
                        return item.MonthName; // Collect category names
                    });

                    var TotalExp = result.map(function (item) {
                        return item.total_price; // Collect category names
                    });

                    Highcharts.chart('containerLineChart', {
                        chart: {
                            type: 'spline'
                        },
                        title: {
                            text: 'Monthly Expenses'
                        },

                        xAxis: {
                            categories: MonthName1,
                            accessibility: {
                                description: 'Months of the year'
                            }
                        },
                        yAxis: {
                            title: {
                                text: 'INR ₹ - Indian Rupee'
                            },
                            labels: {
                                format: '{value}'
                            }
                        },
                        tooltip: {
                            crosshairs: true,
                            shared: true
                        },
                        plotOptions: {
                            spline: {
                                marker: {
                                    radius: 4,
                                    lineColor: '#666666',
                                    lineWidth: 1
                                }
                            }
                        },
                        series: [{
                            name: 'Expenses',
                            marker: {
                                symbol: 'square'
                            },
                            data: TotalExp,
                            dataLabels: {
                                enabled: true,
                                format: '{point.y:.2f}' // Display the total price with 2 decimal places
                            }

                        }]
                    });

                },
                error: function (xhr, status, error) {
                    console.error('AJAX request failed: ' + status + ', ' + error);
                    // Optionally display an error message to the user
                    alert('An error occurred: ' + error);
                }
            });

        }

