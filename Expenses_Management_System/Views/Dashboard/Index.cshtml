        function Bind_Category(m_no) {
            // alert('Bind_Monthly_Spending_Details');

            var monthNumber = parseInt(m_no, 10); // Corrected from monthno to m_no
            if (isNaN(monthNumber)) { monthNumber = 0; }
            $.ajax({
                url: '@Url.Action("Monthly_Spending_Details", "Dashboard")', // Ensure correct controller name
                data: { currentmonth: monthNumber }, // Pass the integer month number
                type: 'GET',
                success: function (result) {
                    //alert('okresult');
                    // Handle the successful response here
                    console.log(result); // Process and display the data
                    // alert(JSON.stringify(result));

                    //******************************************************************************************//
                    var uniqueCategories = {};

                    // Loop through the data to collect unique categories
                    result.forEach(function (item) {
                        if (item.cat_id && item.cat_name) {
                            uniqueCategories[item.cat_id] = item.cat_name;
                        }
                    });
                    //alert(uniqueCategories);
                    // Populate the dropdown
                    var $dropdown = $('#ddlCat');
                    $dropdown.empty(); // Clear existing options

                    // Add default option
                    $dropdown.append('<option value="0">All</option>');

                    // Add options for each unique category
                    $.each(uniqueCategories, function (id, name) {
                        $dropdown.append('<option value="' + id + '">' + name + '</option>');
                    });


                    //******************************************************************************************//

                },
                error: function (xhr, status, error) {
                    alert('An error occurred: ' + error);
                }
            });

