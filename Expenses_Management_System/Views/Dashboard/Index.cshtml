    <script>
        // Data for Highcharts
        function bindDrilldown(m_no) {
           // alert('bindDrilldown--1');
           // alert(m_no);
            $.ajax({
                url: '@Url.Action("GetSubCategoryWiseRPT", "Dashboard")',
                data: { monthn: m_no },
                type: 'GET',
                success: function (result) {
                   // alert('bindDrilldown--2--success');
                    // Handle the data returned from the server here
                    var chartData = result.map(function (item) {
                        return {
                            name: item.cat_name, // Assuming result contains cat_name property
                            y: parseFloat(item.total_price), // Convert total_price to float
                            drilldown: item.cat_id
                        };
                    });

                    // Initialize Data Structure
                    const categories = [];
                    const subCategories = {};
                    const subSubCategories = {};

                    // Process Raw Data
                    result.forEach(item => {
                        // Aggregate Category Data
                        const categoryIndex = categories.findIndex(cat => cat.drilldown === item.cat_id.toString());
                        if (categoryIndex === -1) {
                            categories.push({
                                name: item.cat_name,
                                y: 0,
                                drilldown: item.cat_id.toString()
                            });
                        }
                        categories[categoryIndex !== -1 ? categoryIndex : categories.length - 1].y += item.total_price;

                        // Aggregate Sub-Category Data
                        if (!subCategories[item.cat_id]) {
                            subCategories[item.cat_id] = [];
                        }
                        const subCategoryIndex = subCategories[item.cat_id].findIndex(sub => sub.drilldown === item.cat_id.toString() + '-' + item.subcat_id);
                        if (subCategoryIndex === -1) {
                            subCategories[item.cat_id].push({
                                name: item.subcat_name ,
                                y: 0,
                                drilldown: item.cat_id.toString() + '-' + item.subcat_id
                            });
                        }
                        subCategories[item.cat_id][subCategoryIndex !== -1 ? subCategoryIndex : subCategories[item.cat_id].length - 1].y += item.total_price;

                        // Aggregate Sub-Sub-Category Data
                        const subSubCatKey = item.cat_id.toString() + '-' + item.subcat_id;
                        if (!subSubCategories[subSubCatKey]) {
                            subSubCategories[subSubCatKey] = [];
                        }
                        subSubCategories[subSubCatKey].push({
                            name: item.sub_sub_catName,
                            y: item.total_price
                        });
                    });
                    // Format Data for Highcharts
                    const highchartsData = {
                        categories: categories,
                        subCategories: Object.keys(subCategories).reduce((acc, key) => {
                            acc[key] = subCategories[key];
                            return acc;
                        }, {}),
                        subSubCategories: Object.keys(subSubCategories).reduce((acc, key) => {
                            acc[key] = subSubCategories[key];
                            return acc;
                        }, {})
                    };



                    // Highcharts configuration
                    Highcharts.chart('containerDrilldown', {
                        chart: {
                            type: 'pie'
                        },
                        title: {
                            text: 'Three-Level Drilldown Pie Chart'
                        },
                        series: [{
                            name: 'Category',
                            colorByPoint: true,
                            data: highchartsData.categories
                        }],
                        drilldown: {
                            series: Object.keys(highchartsData.subCategories).map(function (key) {
                                return {
                                    id: key,
                                    name: key.split('-')[1],
                                    data: highchartsData.subCategories[key]
                                };
                            }).concat(Object.keys(highchartsData.subSubCategories).map(function (key) {
                                return {
                                    id: key,
                                    name: key.split('-')[2] || 'Sub-Category',
                                    data: highchartsData.subSubCategories[key]
                                };
                            }))
                        }
                    });
                },
                error: function (xhr, status, error) {
                    console.error('AJAX request failed: ' + status + ', ' + error);
                    // Optionally display an error message to the user
                    alert('An error occurred: ' + error);
                }
            });
        }


    </script>
