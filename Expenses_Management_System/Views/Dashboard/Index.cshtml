    <script defer="">
        // Data retrieved from https://www.ssb.no/en/transport-og-reiseliv/landtransport/statistikk/bilparken
        // Radialize the colors

        $(document).ready(function () {

            $('#ddlMonth').change(function () {
                var catid = $(this).val();
                /*var m_no = $(ddlMonth).val();*/
               // alert(catid);
                bindColumnChart(catid);
                bindPaiChart(catid);
                bindDrilldown(catid);
                CategoryWiseSpendingfun(catid);
                Paymode_Spending(catid);
                BindDonutChart(catid);
                Bind_Category(catid);
                Bind_Monthly_Spending_Details(catid);
            })
            $('#ddlCat').change(function () {
                var catid = $(this).val();
              // alert(catid);
                var m_no = $(ddlMonth).val();
                Bind_Monthly_Spending_DetailsNew(catid, m_no);
            })
            var m_no = $(ddlMonth).val();
            //alert(m_no);
            /* alert('OK');*/
            CategoryWiseSpendingfun(m_no);
            Paymode_Spending(m_no);
            bindColumnChart(m_no);
            bindPaiChart(m_no);
            bindDrilldown(m_no);
            BindLineChart();
            BindDonutChart(m_no);
            Bind_Category(m_no);
            Bind_Monthly_Spending_Details(m_no);

        });

        function Bind_Monthly_Spending_DetailsNew(catid, m_no) {
            // alert('Bind_Monthly_Spending_Details');

            var monthNumber = parseInt(m_no, 10); // Corrected from monthno to m_no
            if (isNaN(monthNumber)) { monthNumber = 0; }
            var Catid = parseInt(catid, 10); // Corrected from monthno to m_no

            $.ajax({
                url: '@Url.Action("Monthly_Spending_Details_new", "Dashboard")', // Ensure correct controller name
                data: { currentmonth: monthNumber, Catidno: Catid }, // Pass the integer month number
                type: 'GET',
                success: function (result) {
                    //alert('okresult');
                    // Handle the successful response here
                    console.log(result); // Process and display the data
                    // alert(JSON.stringify(result));
                    $('#Monthly_Spending_Details').empty();

                    var vtotal = 0;
                    var imageUrl = '@Url.Content("~/Content/Login/OIP.jpeg")';
                    // Populate the table with new data
                    for (var i = 0; i < result.length; i++) {
                        var price = parseFloat(result[i].total_price);
                        vtotal += price;
                        var row = $('<tr>'); // Create a new table row
                        row.append($('<td>').text(i + 1)); // Add row number
                        row.append($('<td style="text-align: left;">').text(result[i].cat_name)); // Add category name
                        row.append($('<td style="text-align: left;">').text(result[i].subcat_name)); // Add price
                        row.append($('<td style="text-align: left;">').text(result[i].sub_sub_catName)); // Add category name
                        row.append($('<td style="text-align: left;">').text(result[i].item_name)); // Add price
                        row.append($('<td style="text-align: right;">').text(result[i].total_price)); // Add price
                        row.append($('<td style="text-align: left;">').text(result[i].PaymentMode)); // Add category name

                        if (result[i].docpath && result[i].docpath.trim() !== '') {
                            var docPathUrl = '@Url.Action("Download", "Dashboard")?fileName=' + encodeURIComponent(result[i].docpath);
                            var link = $('<a>').attr('href', docPathUrl).attr('download', result[i].docpath)
                                .append($('<img>').attr('src', imageUrl).css('height', '20px'));
                            row.append($('<td>').append(link)); // Add document link
                        }
                        $('#Monthly_Spending_Details').append(row); // Append row to table body
                    }
                    var $tfoot = $('#uniqueFooterId');
                    if ($tfoot.length === 0) {
                        // Create new tfoot if not present
                        $tfoot = $('<tfoot id="uniqueFooterId"></tfoot>');
                        $('table').append($tfoot);
                    } else {
                        // Clear existing tfoot if present
                        $tfoot.empty();
                    }
                    // Append new footer content
                    //var tfootRow = $('<tr><td colspan="5"><strong>Total</strong></td><td style="text-align:right"><strong>' + vtotal.toFixed(2) + '</strong></td></tr>');
                    //$tfoot.append(tfootRow); // Append footer row to table footer

                    $('#uniqueFooterId').append('<tr><td colspan="5"><strong>Total</strong></td><td style="text-align:right"><strong>' + vtotal.toFixed(2) + '</strong></td></tr>');
                },
                error: function (xhr, status, error) {
                    alert('An error occurred: ' + error);
                }
            });
        }

