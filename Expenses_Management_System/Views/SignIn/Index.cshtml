@model Expenses_Management_System.Models.user_tbl

@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Index</title>
    <link href="~/Content/deshboard/font-awesome.min.css" rel="stylesheet" />
    <link href="~/Content/deshboard/bootstrap.min.css" rel="stylesheet" />
    @*<script type="text/javascript">
        function redirect() {
            window.location.href = "Account.htm";
        }
    </script>*@
    <link href="~/Content/Login/Login.css" rel="stylesheet" />

  
    <script>
        window.console = window.console || function (t) { };
    </script>

</head>
<body>

    <div>
        <div class="container-fluid">
            <div class="row main-content bg-success text-center">
                <div class="col-md-5 text-center company__info">
                    <h3>EMS</h3>


                    <img alt="EMS" src="~/Content/Login/loboEMS.jpeg" style="
   width: 200px;
   height: 150px;margin-left: 10px;" />
                    <h4 class="company_title">Expenses Managenment System</h4>
                </div>
                <div class="col-md-8 col-xs-12 col-sm-12 login_form ">
                    <div class="container-fluid">
                        <div class="row">
                            <h2>Log In</h2>
                        </div>
                        <div class="row">
                            @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()

            <div class="form-horizontal">
               
                <hr />
               

               

                <div class="form-group">
                  
                    <div class="col-md-10">
                        @Html.EditorFor(model => model.mobile_num, new { htmlAttributes = new { @class = "form-control" } })
                       
                    </div>
                </div>

               
                <div class="form-group">
                    <div class="col-md-offset-2 col-md-10">
                        <input type="submit" value="Login" class="btn btn-default" />
                    </div>
                </div>
            </div>
        }

                        </div>
                        <div class="row">

                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- Footer -->
        <div class="container-fluid text-center footer">

        </div>
    </div>
   
    @*<div>
        @Html.ActionLink("Back to List", "Index")
    </div>*@
</body>
</html>
